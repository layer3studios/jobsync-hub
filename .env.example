# FILE: .env.example — backend environment template. Copy to .env and fill real
# values for local dev. Never commit .env (it is gitignored); this file is
# committed with placeholders only.

# ─── Admin identity (feat/admin-identity) ─────────────────────────
# Admin identity is MongoDB-backed (admin_users) + jm_admin_token cookie. The old
# env-based ADMIN_EMAILS is removed — do not reintroduce it.
#
# Bootstrap admin identities. Comma-separated. Read once by
# src/scripts/seed-initial-admins.js. Delete from prod .env after running.
INITIAL_ADMIN_EMAILS=
# Admin session TTL, hours. Defaults 8.
ADMIN_JWT_TTL_HOURS=8

# ─── Admin analytics (PostHog Query API) ──────────────────────────
# Server-only. The personal key (phx_ prefix) is NEVER exposed to the client and
# must never be committed. When POSTHOG_PERSONAL_API_KEY is empty the
# /api/admin/analytics endpoints return 503 and the rest of the app runs
# normally.
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_PROJECT_ID=228975
POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key_here
# Optional — cache TTL for analytics query results, in milliseconds (default 300000).
ANALYTICS_CACHE_TTL_MS=300000